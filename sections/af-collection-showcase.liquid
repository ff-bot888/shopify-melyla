<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} spacing-style {% if section.settings.color_scheme != blank %}color-{{ section.settings.color_scheme }}{% endif %}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  <div class="af-collection-showcase">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="af-collection-showcase__grid">
        {% for block in section.blocks %}
          {% liquid
            assign block_collection = block.settings.collection
            assign card_title = block.settings.title
            if card_title == blank and block_collection != blank
              assign card_title = block_collection.title
            endif

            assign card_link = block.settings.link
            if card_link == blank and block_collection != blank
              assign card_link = block_collection.url
            endif

            assign card_alt = block.settings.alt_text
            if card_alt == blank
              assign card_alt = card_title
            endif
          %}

          <a
            class="af-collection-showcase__card"
            {% if card_link != blank %}
              href="{{ card_link }}"
            {% else %}
              role="link"
              aria-disabled="true"
            {% endif %}
            {{ block.shopify_attributes }}
          >
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 480, 720, 960, 1200',
                  sizes: '(min-width: 990px) 33vw, 80vw',
                  alt: card_alt
              }}
            {% elsif block.settings.image_url != blank %}
              <img
                src="{{ block.settings.image_url }}"
                alt="{{ card_alt | escape }}"
                loading="lazy"
              >
            {% elsif block_collection != blank and block_collection.featured_image != blank %}
              {{
                block_collection.featured_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 480, 720, 960, 1200',
                  sizes: '(min-width: 990px) 33vw, 80vw',
                  alt: card_alt
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag }}
            {% endif %}

            {% if card_title != blank %}
              <span>{{ card_title | escape }}</span>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "AF Collection Showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP BY COLLECTION"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "External image URL",
          "info": "Use this when the image is hosted outside Shopify files."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "If blank, the selected collection title will be used."
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "info": "If blank, the title will be used."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "If blank, the selected collection link will be used."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AF Collection Showcase",
      "category": "Custom",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
