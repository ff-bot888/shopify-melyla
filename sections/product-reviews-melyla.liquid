<section class="melyla-reviews-section section section--page-width">
  <div class="melyla-product-reviews" data-testid="melyla-product-reviews">
    <h2 class="melyla-product-reviews__title">CUSTOMER REVIEWS</h2>
    <div
      id="judgeme_product_reviews"
      class="jdgm-widget jdgm-review-widget"
      data-product-title="{{ product.title | escape }}"
      data-id="{{ product.id }}"
    >
      {{ product.metafields.judgeme.widget }}
    </div>
  </div>
</section>

{% stylesheet %}
  .melyla-reviews-section {
    display: none !important;
    padding-block: 0 48px;
  }

  .melyla-product-reviews {
    width: 100%;
    min-height: 220px;
  }

  .melyla-product-reviews__title {
    margin: 0 0 20px;
    text-align: center;
    font-size: 50px;
    font-weight: 800;
    line-height: 1.08;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Reviews Melyla",
  "tag": "section",
  "class": "section-wrapper",
  "settings": []
}
{% endschema %}
